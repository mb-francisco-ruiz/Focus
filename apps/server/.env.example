# Postgres (Railway: `railway variables` on the Postgres service)
DATABASE_URL=postgresql://user:pass@host:5432/focus

# Any long random string (dev); Railway env var in production
JWT_SECRET=<generate: openssl rand -hex 32>

# Gemini — enrichment silently skips if unset
GOOGLE_GENERATIVE_AI_API_KEY=

PORT=3001
REDIS_URL=redis://default:pass@host:6379

# Interim single-user login (Railway env vars in prod)
AUTH_USERNAME=
AUTH_PASSWORD=

# Where browsers reach this server (OAuth redirects, Slack events)
PUBLIC_URL=http://localhost:3001

# Google OAuth (Phase 2) — integration routes 503 until set
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Custom Slack app (Phase 2)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
