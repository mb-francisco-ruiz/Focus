# Focus server configuration. Copy to `apps/server/.env` and fill in.
# Only the three under REQUIRED are needed to boot; everything else is optional
# and the matching feature simply stays off until you set it.

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Postgres with the pgvector extension available (see docker-compose.yml for a
# one-command local instance). The server creates the extension + tables on boot.
DATABASE_URL=postgresql://focus:focus@localhost:5432/focus
# Redis (job queue). docker-compose.yml provides one locally.
REDIS_URL=redis://localhost:6379
# Signs auth tokens AND derives the key that encrypts stored OAuth tokens.
# Generate with: openssl rand -hex 32   (keep it stable — changing it logs
# everyone out and makes previously-stored integration tokens undecryptable).
JWT_SECRET=

# ── CORE (have sensible defaults) ────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Public origin browsers use to reach this server — OAuth redirects & Slack
# events are built from it. Set to your deployed URL in production.
PUBLIC_URL=http://localhost:3001

# ── AI (optional; AI features skip cleanly if unset) ─────────────────────────
# Google Gemini API key. Also settable per-user in-app (Settings → AI).
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Override a capability's model, e.g. FOCUS_AI_ROUTE_ENRICH=google:gemini-2.5-pro
# FOCUS_AI_ROUTE_ENRICH=

# ── Google OAuth: Gmail + Calendar (optional) ────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials →
# OAuth client (Web). Authorized redirect URI: <PUBLIC_URL>/integrations/google/callback
# Enable the Gmail API and Google Calendar API on the project. See SETUP.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Slack app (optional) ─────────────────────────────────────────────────────
# Create at https://api.slack.com/apps. Redirect: <PUBLIC_URL>/integrations/slack/callback
# Events request URL: <PUBLIC_URL>/integrations/slack/events. See SETUP.md for scopes.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ── Push notifications: Firebase Cloud Messaging (optional; Android) ─────────
# WebSocket + native desktop notifications work without this.
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# ── Gmail real-time push via Cloud Pub/Sub (optional; hourly polling if unset)─
# Full topic name e.g. projects/<gcp-project>/topics/focus-gmail. Grant
# gmail-api-push@system.gserviceaccount.com Publisher, and add a push
# subscription to <PUBLIC_URL>/integrations/gmail/push.
GMAIL_PUBSUB_TOPIC=

# ── File storage: AWS S3 (optional; Postgres bytea used until set) ───────────
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
